# OpsTwin Environment Variables
# Copy this to .env.local and fill in values

# Database (SQLite for local, Postgres for production)
DATABASE_URL="file:./dev.db"
# For production on Vercel with Neon/PlanetScale:
# DATABASE_URL="postgresql://user:pass@host/opstwin?sslmode=require"

# GitHub Integration (for auto-branch + PR creation)
GITHUB_TOKEN=""
GITHUB_APP_ID=""
GITHUB_PRIVATE_KEY=""

# Slack (for notifications)
SLACK_WEBHOOK_URL=""

# Optional: OpenAI for pattern clustering
OPENAI_API_KEY=""

# App
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# Vercel (auto-set when deployed)
# VERCEL_URL=""
