# OpsTwin Environment Variables
# Copy this to .env.local and fill in values

# Database (SQLite for local, Postgres for production)
DATABASE_URL="file:./dev.db"

# Auth (optional — set OPSTWIN_ADMIN_PASSWORD to enable login)
OPSTWIN_ADMIN_PASSWORD=""
OPSTWIN_API_KEY=""
OPSTWIN_AUTH_DISABLED="true"

# LLM planning — Groq (recommended) or OpenAI
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
LLM_PROVIDER="groq"

# Auto-watch loop
OPSTWIN_AUTO_PROPOSE="true"

# Cursor SDK (for CLI: node opstwin-cli.js loop — runs agents in your repo)
# CURSOR_API_KEY=""
# CURSOR_MODEL="composer-2.5"
# OPSTWIN_AUTO_RUN="true"
OPSTWIN_LLM_PROPOSE="true"

# App
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# CLI (set in target repo shell, not OpsTwin server)
# OPSTWIN_URL=http://localhost:3000
# OPSTWIN_TASK_ID=
# OPSTWIN_API_KEY=  (must match server if auth enabled)

# Slack (for notifications — future)
SLACK_WEBHOOK_URL=""
