// prisma/schema.prisma
// OpsTwin — Full database schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Task {
  id              String           @id @default(cuid())
  user            String
  repo            String
  branch          String
  originalPrompt  String
  title           String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  runs            CursorRun[]
  plans           Plan[]
  prompts         PromptProposal[]
  capturedPrompts CapturedPrompt[]
}

model Plan {
  id             String           @id @default(cuid())
  taskId         String
  task           Task             @relation(fields: [taskId], references: [id])
  version        Int              @default(1)
  originalPrompt String
  stepsJson      String
  documentsJson  String
  status         String           @default("draft")
  approvedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  prompts        PromptProposal[]
}

model CliConnection {
  taskId   String   @id
  repoPath String   @default("")
  mode     String   @default("daemon")
  pid      Int?
  autoRun  Boolean  @default(false)
  lastSeen DateTime @updatedAt
}

model CliRunRequest {
  id         String    @id @default(cuid())
  taskId     String
  proposalId String?
  prompt     String
  status     String    @default("pending") // pending|running|completed|failed
  error      String?
  createdAt  DateTime  @default(now())
  startedAt  DateTime?
  finishedAt DateTime?
}

model PromptProposal {
  id             String    @id @default(cuid())
  taskId         String
  task           Task      @relation(fields: [taskId], references: [id])
  planId         String?
  plan           Plan?     @relation(fields: [planId], references: [id])
  runId          String?
  planStepOrder  Int?
  proposedPrompt String
  rationale      String
  status         String    @default("draft")
  userEdits      String?
  approvedAt     DateTime?
  dispatchedAt   DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime  @default(now())
}

model CursorRun {
  id             String          @id @default(cuid())
  taskId         String
  task           Task            @relation(fields: [taskId], references: [id])
  startedAt      DateTime        @default(now())
  finishedAt     DateTime?
  status         String          @default("running")  // running|complete|failed|partial
  confidence     String?         // high|medium|low
  branch         String
  cursorVersion  String?
  fileEdits      FileEdit[]
  inspectedFiles InspectedFile[]
  expectations   Expectation?
  outcomes       Outcome[]
  terminalLogs   TerminalLog[]
  screenshots    RunScreenshot[]
  auditJson         String?  // full JSON blob of the .ops/runs/<id>/last_run.json
  stackContextJson  String?  // JSON stack context from CLI collector
}

model CapturedPrompt {
  id         String   @id @default(cuid())
  taskId     String
  task       Task     @relation(fields: [taskId], references: [id])
  source     String   // inbound_file | dashboard | agent_audit
  content    String
  capturedAt DateTime @default(now())
}

model TerminalLog {
  id         String    @id @default(cuid())
  runId      String
  run        CursorRun @relation(fields: [runId], references: [id])
  command    String
  exitCode   Int
  stdout     String    @default("")
  stderr     String    @default("")
  capturedAt DateTime  @default(now())
}

model RunScreenshot {
  id         String    @id @default(cuid())
  runId      String
  run        CursorRun @relation(fields: [runId], references: [id])
  label      String    @default("screenshot")
  dataUrl    String
  capturedAt DateTime  @default(now())
}

model AuthSession {
  id        String   @id @default(cuid())
  token     String   @unique
  user      String   @default("admin")
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model FileEdit {
  id           String    @id @default(cuid())
  runId        String
  run          CursorRun @relation(fields: [runId], references: [id])
  path         String
  diff         String
  linesAdded   Int       @default(0)
  linesRemoved Int       @default(0)
}

model InspectedFile {
  id      String    @id @default(cuid())
  runId   String
  run     CursorRun @relation(fields: [runId], references: [id])
  path    String
  reason  String
  touched Boolean   @default(false)
}

model Expectation {
  id              String    @id @default(cuid())
  runId           String    @unique
  run             CursorRun @relation(fields: [runId], references: [id])
  expectedFiles   String    // JSON array
  expectedChanges String
  expectedTests   String    // JSON array
}

model Outcome {
  id           String    @id @default(cuid())
  runId        String
  run          CursorRun @relation(fields: [runId], references: [id])
  action       String    // accepted|rejected|modified|rerun
  userFeedback String?
  timeToFixMs  Int?
  acceptedAt   DateTime  @default(now())
}

model MemoryEntry {
  id                    String   @id @default(cuid())
  taskType              String
  patternHash           String   @unique
  outcomeSummary        String
  improvementSuggestion String
  reuseCount            Int      @default(0)
  successRate           Float    @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
